# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_NAME=SafeGuard
APP_URL=https://api.safeguard.app
CLIENT_URL=https://safeguard.app

# ─── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/safeguard?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/safeguard_test

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=<min-64-char-random-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<min-64-char-random-refresh-secret>
JWT_REFRESH_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=<redis-password>
REDIS_TLS=false

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=<sendgrid-api-key>
EMAIL_FROM=noreply@safeguard.app
EMAIL_FROM_NAME=SafeGuard

# ─── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<twilio-sid>
TWILIO_AUTH_TOKEN=<twilio-token>
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=<razorpay-key-id>
RAZORPAY_KEY_SECRET=<razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay-webhook-secret>

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<key>
STRIPE_PUBLISHABLE_KEY=pk_live_<key>
STRIPE_WEBHOOK_SECRET=whsec_<secret>

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://safeguard.app,https://www.safeguard.app

# ─── BullMQ ────────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5

# ─── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=<32-byte-hex-encryption-key>

# ─── ML Risk Model (optional) ──────────────────────────────────────────────────
# Leave blank to use the built-in rule-based fallback (no external service needed)
# Set to your FastAPI/Flask microservice URL to enable ML scoring
ML_MODEL_URL=
# e.g. ML_MODEL_URL=http://localhost:8000
# e.g. ML_MODEL_URL=https://your-ml-service.onrender.com

ML_MODEL_TIMEOUT_MS=3000
# How long to wait for ML service before falling back to rules (milliseconds)

ML_MODEL_API_KEY=
# Optional bearer token for authenticating to the ML service

