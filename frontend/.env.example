# ─── Vite Public Env ──────────────────────────────────────────────────────────
# These are injected at build time via import.meta.env
# Only VITE_ prefixed vars are exposed to the browser

VITE_APP_NAME=SafeGuard
VITE_APP_URL=https://safeguard.app

# Razorpay publishable key (safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx

# Stripe publishable key (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
